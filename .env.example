# PostgreSQL (Hostinger VPS)
PGHOST=your-db-host.hostinger.com
PGPORT=5432
PGDATABASE=ziarem
PGUSER=your_user
PGPASSWORD=your_password
PGSSLMODE=require

# API
PORT=3000

# Omni-SMTP: tracking pixel base URL (open tracking)
TRACKING_BASE_URL=https://ziarem.com/api/track

# Optional: free API integrations (lead enrichment). Leave unset to skip.
# Geocoding (Nominatim) and IP geo (ip-api.com) work with no key.
# Abstract API: https://www.abstractapi.com (email + phone, 100 free/month each)
# NumVerify: https://numverify.com (250 free/month)
ABSTRACT_EMAIL_API_KEY=
ABSTRACT_PHONE_API_KEY=
NUMVERIFY_API_KEY=
