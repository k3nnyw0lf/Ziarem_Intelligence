# Supabase (Next.js / dashboard) - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge Function secrets (set in Supabase Dashboard → Settings → Edge Functions)
# GEMINI_API_KEY=your-google-gemini-api-key  (https://aistudio.google.com/apikey)

# Optional free APIs (see docs/FREE_APIS.md)
# RESEND_API_KEY=re_xxx          # Resend (email) - resend.com
# NEXT_PUBLIC_VAPI_PUBLIC_KEY=   # Vapi (telephony) - vapi.ai
