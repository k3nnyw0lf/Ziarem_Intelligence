# Supabase (Next.js / dashboard) - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge Function secrets (set in Supabase Dashboard → Settings → Edge Functions)
# GEMINI_API_KEY=your-google-gemini-api-key  (https://aistudio.google.com/apikey)

# Ziarem.com API routes (server-side)
# SUPABASE_SERVICE_ROLE_KEY=    # Required for /api/webhooks (bypass RLS)
# N8N_WEBHOOK_ONBOARDING_URL=   # n8n (Hostinger) webhook for bilingual onboarding emails

# Optional free APIs (see docs/FREE_APIS.md)
# RESEND_API_KEY=re_xxx          # Resend (email) - resend.com
# NEXT_PUBLIC_VAPI_PUBLIC_KEY=   # Vapi (telephony) - vapi.ai

# --- Ziarem Intelligence (Node API / Hostinger VPS) ---
# PostgreSQL (Hostinger VPS)
PGHOST=your-db-host.hostinger.com
PGPORT=5432
PGDATABASE=ziarem
PGUSER=your_user
PGPASSWORD=your_password
PGSSLMODE=require

# API
PORT=3000

# Omni-SMTP: tracking pixel base URL (open tracking)
TRACKING_BASE_URL=https://ziarem.com/api/track

# Optional: lead enrichment (Abstract API, NumVerify)
ABSTRACT_EMAIL_API_KEY=
ABSTRACT_PHONE_API_KEY=
NUMVERIFY_API_KEY=
