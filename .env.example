# ============== Next.js (CRM dashboard + API routes) ==============
# Supabase - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side (webhooks, score-leads, assemble-persona)
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

# Optional
N8N_WEBHOOK_ONBOARDING_URL=
CRON_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DOCUSIGN_API_URL=
DOCUSIGN_API_KEY=
PLACEHOLDER_SIGNING_URL=
TCPA_FIREWALL_URL=
TCPA_FIREWALL_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_APP_URL=https://ziarem.com
# Phase 7 Live Canvas: notify Vapi when prospect opens portal
VAPI_PRIVATE_KEY=
VAPI_CONTROL_BASE_URL=https://api.vapi.ai

# Phase 8 Executive CRM (Twilio inbound)
EXECUTIVE_ALLOWED_CALLER_ID=
KEN_PHONE_NUMBER=
N8N_LAENAN_LINKS_WEBHOOK_URL=
SWARM_WS_PORT=3100

# Phase 9 Vision Render (property image + style → SMS)
VISION_RENDER_IMAGE_API_URL=
VISION_RENDER_STYLE_API_URL=

# ============== Ziarem Intelligence (Node API) ==============
# PostgreSQL (Hostinger VPS)
PGHOST=your-db-host.hostinger.com
PGPORT=5432
PGDATABASE=ziarem
PGUSER=your_user
PGPASSWORD=your_password
PGSSLMODE=require

# Use 3001 when running alongside Next.js (Next.js uses 3000)
PORT=3001
API_KEY=
TRACKING_BASE_URL=https://ziarem.com/api/track

# Lead enrichment (optional)
ABSTRACT_EMAIL_API_KEY=
ABSTRACT_PHONE_API_KEY=
NUMVERIFY_API_KEY=

# =========================================================================
# LLM router — fill any/all. Router cascades cheapest → most expensive.
# Provider priority is set in llm_provider_quota; you can re-rank in SQL.
# Note: GEMINI_API_KEY above is shared with the Next.js side; one key serves both.
# =========================================================================

# ----- TIER 1 (FREE, local) — Ollama on Synology NAS -----
# Pull these models on Synology first:
#   ollama pull nomic-embed-text   # 768d embeddings
#   ollama pull qwen2.5:7b         # JSON-strong, ~4.4GB
OLLAMA_BASE_URL=http://dosmortgage.us6.quickconnect.to:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ----- TIER 2 (FREE API) — Google AI Studio (uses GEMINI_API_KEY above) -----
# Get key: https://aistudio.google.com/app/apikey  (free tier 1500/day, 15 RPM, gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ----- TIER 3 (FREE API) — Groq (fastest) -----
# Get key: https://console.groq.com  (free tier 30 RPM, ~14400/day)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ----- TIER 4 (FREE API) — OpenRouter (gateway, mix of free models) -----
# Get key: https://openrouter.ai/keys  (free models include DeepSeek-R1, Gemini-2.5-flash-exp, Llama-3.3-70b)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# ----- TIER 5 (FREE API) — Cloudflare Workers AI -----
# You already have a Cloudflare account (per CLAUDE.md). Free 10K neurons/day.
# https://dash.cloudflare.com/profile/api-tokens  (Workers AI — Read+Run)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CF_EMBED_MODEL=@cf/baai/bge-base-en-v1.5

# ----- TIER 6 (FREE via Google One AI Premium) — Gemini CLI subprocess -----
# Disabled by default; enable only when you accept slow latency + interactive ToS.
# To enable: set GEMINI_CLI_ENABLED=true AND
#   psql -c "UPDATE llm_provider_quota SET enabled=TRUE WHERE provider='gemini-cli'"
GEMINI_CLI_ENABLED=false
GEMINI_CLI_MODEL=gemini-2.5-flash

# ----- TIER 7 (PAID FALLBACK) — Anthropic Claude -----
# Only used when free tiers are over their daily cap or all errored.
# $5/day caps are set in llm_provider_quota — adjust there.
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_OPUS_MODEL=claude-opus-4-7
ANTHROPIC_OPUS_ENABLED=false

# ----- n8n inbox webhook -----
# Shared secret for POST /inbox/webhook/n8n. Generate a random string and paste
# the same value into the X-Webhook-Secret header of each n8n HTTP Request node.
N8N_WEBHOOK_SECRET=
