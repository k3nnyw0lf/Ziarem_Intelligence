# Ziarem agent fleet — global env.
# Copy to hermes/agents/.env on the VPS and fill in.
#
#   cp hermes/agents/.env.example hermes/agents/.env
#   $EDITOR hermes/agents/.env

# ─── Shared LLM keys (any provider you want the fleet to use) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Skyvern ────────────────────────────────────────────────────────────────
SKYVERN_API_KEY=                           # generate any random hex string
SKYVERN_DATABASE_STRING=postgresql://skyvern:skyvern@skyvern-postgres/skyvern

# ─── Crawl4AI ───────────────────────────────────────────────────────────────
CRAWL4AI_API_TOKEN=                        # generate any random hex string

# ─── Mem0 ───────────────────────────────────────────────────────────────────
MEM0_PG_PASSWORD=                          # generate strong random
MEM0_DATABASE_URL=postgresql://mem0:${MEM0_PG_PASSWORD}@mem0-postgres:5432/mem0

# ─── Pipecat (voice) ────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
VAPI_PRIVATE_KEY=

# ─── OpenHands ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=                              # PAT with repo scope on Ziarem repos
