# Hermes Agent — Ziarem environment overrides
# Destination: ~/.hermes/.env
# Hermes reads this on startup; values here override config.yaml.

# ─── Inference provider ──────────────────────────────────────────────────────
# Ziarem already uses Gemini for transcript extraction; reuse the same key.
GEMINI_API_KEY=

# Optional fallbacks — Hermes will try these in order if Gemini fails.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ─── GitHub (for Skills Hub rate limit + repo skills) ────────────────────────
GITHUB_TOKEN=

# ─── Messaging gateway tokens ────────────────────────────────────────────────
# Fill only the channels you actually run. Anything blank stays disabled.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SIGNAL_PHONE_NUMBER=

# WhatsApp: pick ONE source of truth. Either Hermes' built-in integration
# (set the token below) or the existing wa-bridge/ service — never both
# against the same WhatsApp session, or the QR will keep cycling.
WHATSAPP_API_TOKEN=

# ─── Ziarem data plane (so Hermes can answer lead/call/cross-sell questions) ─
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=ziarem
PGSSLMODE=require

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Outbound SMTP (only if you let Hermes own a "from" address) ─────────────
# Otherwise leave blank and keep `omni_sender.js` as the email path.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── n8n webhook (cross-sell trigger) ───────────────────────────────────────
N8N_WEBHOOK_ONBOARDING_URL=

# ─── Optional research/web skills ────────────────────────────────────────────
# Uncomment any you want to enable in `hermes doctor`.
# EXA_API_KEY=
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# PARALLEL_API_KEY=
